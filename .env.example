# ============================================================
# Finance ETL — Environment Configuration
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to source control.
# ============================================================

# --- Application ---
APP_ENV=development                  # development | staging | production
APP_NAME=finance_etl
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | console

# --- Oracle (Transactions source) ---
ORACLE_HOST=oracle.example.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=ORCLPDB1
ORACLE_USER=finance_etl_reader
ORACLE_PASSWORD=__PLACEHOLDER__
ORACLE_POOL_SIZE=5

# --- PostgreSQL (Customer master) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finance_etl_master
POSTGRES_USER=finance_etl
POSTGRES_PASSWORD=__PLACEHOLDER__

# --- REST APIs ---
OPENEXCHANGE_API_KEY=__PLACEHOLDER__
OPENEXCHANGE_BASE_URL=https://openexchangerates.org/api
ALPHAVANTAGE_API_KEY=__PLACEHOLDER__
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query

# --- SFTP (Partner files) ---
SFTP_HOST=sftp.partner.example.com
SFTP_PORT=22
SFTP_USERNAME=finance_etl_etl
SFTP_PRIVATE_KEY_PATH=/secrets/sftp_rsa
SFTP_REMOTE_DIR=/inbound/finance_etl

# --- Snowflake (DW target) ---
SNOWFLAKE_ACCOUNT=abc12345.us-east-1
SNOWFLAKE_USER=finance_etl_etl
SNOWFLAKE_PASSWORD=__PLACEHOLDER__
SNOWFLAKE_WAREHOUSE=FINANCE_ETL_WH
SNOWFLAKE_DATABASE=FINANCE_ETL_DW
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=FINANCE_ETL_ETL_ROLE

# --- AWS S3 (Data Lake target) ---
AWS_ACCESS_KEY_ID=__PLACEHOLDER__
AWS_SECRET_ACCESS_KEY=__PLACEHOLDER__
AWS_REGION=us-east-1
S3_BUCKET=finance_etl-data-lake
S3_PREFIX=raw/

# --- Redis (Fraud alerts + DLQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_FRAUD_STREAM=finance_etl:fraud:alerts
REDIS_DLQ_KEY=finance_etl:dlq

# --- Pipeline tuning ---
PIPELINE_BATCH_SIZE=10000
PIPELINE_MAX_RETRIES=5
PIPELINE_RETRY_BACKOFF=2.0
PIPELINE_TIMEOUT_SECONDS=300
PIPELINE_BASE_CURRENCY=USD

# --- Fraud thresholds ---
FRAUD_VELOCITY_TXN_PER_HOUR=10
FRAUD_HIGH_VALUE_THRESHOLD_USD=10000
FRAUD_ZSCORE_THRESHOLD=3.0

# --- Metrics ---
PROMETHEUS_PORT=8000
ENABLE_METRICS=true
